# ===========================================================================
# .env.example — template di configurazione per il backend serverDati.
# Copia in ".env" e personalizza i valori per il tuo ambiente locale.
# Il file ".env" è ignorato da git (vedi .gitignore).
# ===========================================================================

serverPort=8080

darkMode=true

HMI_option = {"darkMode":true,"language":["IT","EN"]}

# Path della directory contenente i modelli grating per la HMI.
# Personalizza col path reale del tuo ambiente.
# Esempio Windows: C:\Users\<user>\path\to\models\
# Esempio Linux:   /opt/easybox/models/
Grating_model_dir = "D:\path\to\easybox\Models\"

# URL broker MQTT (mosquitto). Se assente, fallback al valore storico interno al codice.
# Esempio produzione: mqtt://HMI:HMI@172.20.70.80:9001
#MQTT_BROKER_URL=mqtt://user:pass@host:9001

# Tipo CNC per macchina. Valori validi: heidenhain (default), haas.
# Se assente o invalido, fallback a heidenhain (backwards-compat impianti esistenti).
#CN_TYPE_MC1=heidenhain
#CN_TYPE_MC2=heidenhain

# Configurazione HAAS — attivare quando MC<n> è cablata e CN_TYPE_MC<n>=haas
#HAAS_MC1_IP=192.168.30.36
#HAAS_MC1_PORT=5000
#HAAS_TIMEOUT_MS=2000
#HAAS_PROGRAM_TRIGGER_VAR=500
